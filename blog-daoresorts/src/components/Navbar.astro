---
// src/components/Navbar.astro
---
<nav class="glass-nav fixed top-0 w-full z-[100] h-16 flex items-center transition-all duration-300">
  <div class="max-w-[1200px] w-full mx-auto px-6 md:px-0 flex justify-between items-center h-full">
    
    {/* Logo */}
    <a href="https://daoresorts.club" class="font-playfair text-xl md:text-2xl font-bold text-text-primary flex items-end tracking-wide hover:opacity-80 transition-opacity">
      DAOResorts <span class="text-accent-gold ml-1 w-2 h-2 rounded-full bg-accent-gold mb-1.5 md:mb-2 flex shrink-0"></span> <span class="text-sm font-sans font-normal ml-1 mb-0.5 md:mb-1 opacity-80">club</span>
    </a>

    {/* Desktop Links */}
    <div class="hidden md:flex items-center gap-8">
      <a href="/blog" class="text-sm uppercase tracking-[0.08em] font-medium text-text-primary border-b-2 border-accent-gold pb-1 transition-colors">
        Blog
      </a>
      <a href="https://daoresorts.club" class="text-sm uppercase tracking-[0.08em] font-medium text-text-secondary hover:text-text-primary transition-colors">
        O Projekcie
      </a>
      <a href="https://daoresorts.club/#resorty" class="text-sm uppercase tracking-[0.08em] font-medium text-text-secondary hover:text-text-primary transition-colors">
        Resort
      </a>
      <a href="https://daoresorts.club/#faq" class="text-sm uppercase tracking-[0.08em] font-medium text-text-secondary hover:text-text-primary transition-colors">
        FAQ
      </a>
    </div>

    {/* CTA & Mobile Menu Toggle */}
    <div class="flex items-center gap-4">
      <a
        href="https://daoresorts.club"
        class="hidden md:inline-flex bg-accent-gold text-bg-primary font-bold text-sm px-5 py-2.5 rounded-btn hover:bg-accent-gold-hover transition-colors shadow-btn"
      >
        Dołącz do klubu &rarr;
      </a>
      
      {/* Mobile Hamburger (React or Vanilla JS, here we can use Vanilla JS for Astro) */}
      <button id="mobile-menu-btn" class="md:hidden text-text-primary p-2 focus:outline-none" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile Menu Overlay */}
  <div id="mobile-menu" class="fixed inset-0 bg-bg-primary z-[90] flex flex-col pt-24 px-6 md:hidden transition-transform duration-300 translate-x-full">
    <div class="flex flex-col gap-6 text-center">
      <a href="/blog" class="text-xl font-playfair font-bold text-text-primary border-b border-border-subtle pb-4">Blog</a>
      <a href="https://daoresorts.club" class="text-xl font-playfair text-text-secondary hover:text-text-primary border-b border-border-subtle pb-4">O Projekcie</a>
      <a href="https://daoresorts.club/#resorty" class="text-xl font-playfair text-text-secondary hover:text-text-primary border-b border-border-subtle pb-4">Resort</a>
      <a href="https://daoresorts.club/#faq" class="text-xl font-playfair text-text-secondary hover:text-text-primary pb-6">FAQ</a>
      <a
        href="https://daoresorts.club"
        class="bg-accent-gold text-bg-primary font-bold text-lg px-6 py-3 rounded-btn mt-4 shadow-btn w-full"
      >
        Dołącz do klubu &rarr;
      </a>
    </div>
  </div>
</nav>

<script>
  // Simple vanilla JS for mobile menu
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    let isOpen = false;

    if (btn && menu) {
      btn.addEventListener('click', () => {
        isOpen = !isOpen;
        if (isOpen) {
          menu.classList.remove('translate-x-full');
          document.body.style.overflow = 'hidden';
          // Change icon to close
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>`;
        } else {
          menu.classList.add('translate-x-full');
          document.body.style.overflow = '';
          // Change icon to menu
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>`;
        }
      });
    }
  });
</script>
