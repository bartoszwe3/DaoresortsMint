---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import { PortableText } from '@portabletext/react';
import { format } from 'date-fns';
import { pl } from 'date-fns/locale';
import CategoryBadge from '../../components/CategoryBadge.astro';

export async function getStaticPaths() {
  const query = `*[_type == "post"] {
    "slug": slug.current
  }`;
  console.log('[DEBUG] slug.astro getStaticPaths fetching posts...');
  const posts = await sanityClient.fetch(query);
  console.log('[DEBUG] Found posts for slugs:', posts.length);
  
  return posts.map((post: any) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;

const query = `*[_type == "post" && slug.current == $slug][0] {
  title,
  publishedAt,
  coverImage,
  kategoria,
  author,
  body,
  excerpt
}`;

const post = await sanityClient.fetch(query, { slug });

if (!post) {
  return Astro.redirect('/404');
}
---

<BaseLayout 
  title={post.title} 
  description={post.excerpt} 
  image={post.coverImage ? urlFor(post.coverImage).url() : undefined}
  type="article"
>
  <article class="max-w-[800px] mx-auto px-4">
    <header class="mb-12">
      <div class="flex items-center gap-4 mb-6">
        <CategoryBadge category={post.kategoria} />
        <time class="text-text-muted font-sans text-sm">
          {post.publishedAt ? format(new Date(post.publishedAt), 'd MMMM yyyy', { locale: pl }) : 'Brak daty'}
        </time>
      </div>
      
      <h1 class="text-4xl md:text-6xl font-playfair font-bold text-text-primary mb-8 leading-tight">
        {post.title}
      </h1>
      
      {post.author && (
        <div class="flex items-center gap-3 text-text-secondary font-sans font-medium">
          <span>Autor: {post.author}</span>
        </div>
      )}
    </header>

    {post.coverImage && (
      <div class="mb-12 rounded-2xl overflow-hidden shadow-2xl aspect-video bg-bg-surface">
        <img 
          src={urlFor(post.coverImage).width(1200).url()} 
          alt={post.title}
          class="w-full h-full object-cover"
        />
      </div>
    )}

    <div class="prose prose-invert prose-lg max-w-none font-sans text-text-primary leading-relaxed
      prose-headings:font-playfair prose-headings:text-text-primary
      prose-p:text-text-secondary prose-p:mb-6
      prose-a:text-accent-gold prose-a:no-underline hover:prose-a:underline
      prose-strong:text-text-primary
      prose-img:rounded-xl prose-img:shadow-lg">
      <PortableText value={post.body} />
    </div>

    <footer class="mt-16 pt-8 border-t border-border-subtle">
      <a href="/blog" class="inline-flex items-center text-accent-gold font-sans font-bold hover:gap-3 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Wróć do bloga
      </a>
    </footer>
  </article>
</BaseLayout>
