---
const { category } = Astro.props;

// Determine colors based on category
let bgClass = "bg-accent-gold-muted text-accent-gold";
let borderClass = "border-accent-gold/30";

if (category === "Aktualności") {
  bgClass = "bg-accent-gold-muted text-accent-gold";
  borderClass = "border-accent-gold/30";
} else if (category === "Budowa") {
  bgClass = "bg-bg-elevated text-text-primary";
  borderClass = "border-border-default";
} else if (category === "Web3 i NFT") {
  bgClass = "bg-accent-green/20 text-accent-green";
  borderClass = "border-accent-green/30";
} else if (category === "Prawo i Finanse") {
  bgClass = "bg-bg-surface text-text-secondary";
  borderClass = "border-text-secondary/30";
} else if (category === "Lifestyle") {
  bgClass = "bg-[#C9A84C]/10 text-[#C9A84C]";
  borderClass = "border-[#C9A84C]/30";
}
---
<span class={`inline-block px-3 py-1 text-xs font-sans font-bold uppercase tracking-wider rounded-badge border backdrop-blur-md ${bgClass} ${borderClass}`}>
  {category}
</span>
