---
// src/components/Footer.astro
const year = new Date().getFullYear();
---
<footer class="bg-bg-primary border-t border-border-subtle pt-16 pb-8 mt-20">
  <div class="max-w-[1200px] w-full mx-auto px-6 md:px-0">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8 mb-16">
      <div class="md:col-span-2">
        <a href="https://daoresorts.club" class="font-playfair text-2xl font-bold text-text-primary flex items-end tracking-wide mb-4">
          DAOResorts <span class="text-accent-gold ml-1 w-2 h-2 rounded-full bg-accent-gold mb-1.5 flex shrink-0"></span> <span class="text-sm font-sans font-normal ml-1 mb-0.5 opacity-80">club</span>
        </a>
        <p class="text-text-secondary font-medium tracking-wide max-w-sm">PIERWSZY WEB3 VACATION CLUB W EUROPIE</p>
      </div>
      
      <div>
        <h4 class="font-sans font-bold text-text-primary tracking-[0.08em] uppercase mb-4 text-sm">Blog</h4>
        <ul class="space-y-3">
          <li><a href="/blog" class="text-text-secondary hover:text-accent-gold transition-colors text-sm">Wszystkie wpisy</a></li>
          <li><a href="/blog/kategoria/aktualnosci" class="text-text-secondary hover:text-accent-gold transition-colors text-sm">Aktualności</a></li>
          <li><a href="/blog/kategoria/budowa" class="text-text-secondary hover:text-accent-gold transition-colors text-sm">Budowa</a></li>
          <li><a href="/blog/kategoria/web3-i-nft" class="text-text-secondary hover:text-accent-gold transition-colors text-sm">Web3 i NFT</a></li>
          <li><a href="/blog/kategoria/prawo-i-finanse" class="text-text-secondary hover:text-accent-gold transition-colors text-sm">Prawo i Finanse</a></li>
          <li><a href="/blog/kategoria/lifestyle" class="text-text-secondary hover:text-accent-gold transition-colors text-sm">Lifestyle</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-sans font-bold text-text-primary tracking-[0.08em] uppercase mb-4 text-sm">DAOResorts</h4>
        <ul class="space-y-3">
          <li><a href="https://daoresorts.club" class="text-text-secondary hover:text-accent-gold transition-colors text-sm">Strona główna</a></li>
          <li><a href="https://daoresorts.club/#resorty" class="text-text-secondary hover:text-accent-gold transition-colors text-sm">Nasz resort</a></li>
          <li><a href="https://daoresorts.club/#faq" class="text-text-secondary hover:text-accent-gold transition-colors text-sm">FAQ</a></li>
          <li><a href="https://daoresorts.club" class="text-text-secondary hover:text-accent-gold transition-colors text-sm">Dołącz do klubu</a></li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-border-subtle pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-text-muted text-xs">&copy; {year} DAOResorts. Wszelkie prawa zastrzeżone.</p>
      <div class="flex gap-4">
        <a href="https://daoresorts.club/regulamin" class="text-text-muted hover:text-text-primary text-xs transition-colors">Regulamin</a>
        <a href="https://daoresorts.club/polityka-prywatnosci" class="text-text-muted hover:text-text-primary text-xs transition-colors">Polityka Prywatności</a>
      </div>
    </div>
  </div>
</footer>
